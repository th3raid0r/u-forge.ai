## Testing Patterns

### Isolated tests with TempDir (standard pattern)

```rust
#[cfg(test)]
mod tests {
    use super::*;
    use tempfile::TempDir;

    fn create_test_graph() -> (KnowledgeGraph, TempDir) {
        let temp = TempDir::new().unwrap();
        // KnowledgeGraph::new takes ONE argument — the db directory path
        let graph = KnowledgeGraph::new(temp.path()).unwrap();
        (graph, temp)
    }

    #[test]
    fn test_something() {
        let (graph, _tmp) = create_test_graph();
        // _tmp must stay alive — TempDir deletes on drop
        // ...
    }
}
```

### Mock embedding provider (for queue / search tests — no server required)

```rust
struct MockEmbeddingProvider { dimensions: usize }

#[async_trait]
impl EmbeddingProvider for MockEmbeddingProvider {
    async fn embed(&self, text: &str) -> Result<Vec<f32>> {
        // Deterministic fake: varies by text length so results differ
        Ok((0..self.dimensions)
            .map(|i| (text.len() as f32 + i as f32) / 1000.0)
            .collect())
    }
    async fn embed_batch(&self, texts: Vec<String>) -> Result<Vec<Vec<f32>>> {
        let mut out = Vec::new();
        for t in &texts { out.push(self.embed(t).await?); }
        Ok(out)
    }
    fn dimensions(&self) -> Result<usize> { Ok(self.dimensions) }
    fn max_tokens(&self) -> Result<usize> { Ok(512) }
    fn provider_type(&self) -> EmbeddingProviderType { EmbeddingProviderType::Lemonade }
    fn model_info(&self) -> Option<EmbeddingModelInfo> { None }
}
```

### Lemonade integration tests (skipped when server not available)

```rust
fn lemonade_url() -> Option<String> {
    std::env::var("LEMONADE_URL").ok()
}

#[tokio::test]
async fn test_real_embedding() {
    let Some(url) = lemonade_url() else {
        eprintln!("Skipping: LEMONADE_URL not set");
        return;
    };
    let provider = LemonadeProvider::new(&url, "nomic-embed-text").await.unwrap();
    let vec = provider.embed("test").await.unwrap();
    assert_eq!(vec.len(), provider.dimensions().unwrap());
}
```

